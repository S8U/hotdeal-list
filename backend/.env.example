# Spring Profile (local | prod)
SPRING_PROFILES_ACTIVE=local

# Application Mode (API | CRAWLING_API)
APP_MODE=API

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hotdeal_db
DB_USERNAME=user
DB_PASSWORD=password

# Server Configuration
SERVER_PORT=8080

# URL Configuration
BASE_URL_API=http://localhost:8080
BASE_URL_FRONTEND=http://localhost:3000

# AI Configuration
OPENAI_API_KEY=

# Elasticsearch Configuration
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# File Storage Configuration
FILE_STORE_TYPE=local

# Local Storage
FILE_STORE_LOCAL_PATH=./storage
FILE_STORE_LOCAL_URL=http://localhost:8080/storage

# S3/R2 Storage
FILE_STORE_S3_BUCKET=
FILE_STORE_S3_BASE_URL=
FILE_STORE_S3_ENDPOINT=
FILE_STORE_S3_ACCESS_KEY=
FILE_STORE_S3_SECRET_KEY=
FILE_STORE_S3_REGION=auto